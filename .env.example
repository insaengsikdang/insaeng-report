# ================================================
# GA4 일간 리포트 - 환경변수 설정
# ================================================
# 이 파일을 복사하여 .env 파일을 만들어주세요:
#   cp .env.example .env

# --------------------------------------------------
# Google Analytics 4
# --------------------------------------------------
# GA4 속성 ID (형식: properties/1234567890)
GA4_PROPERTY_ID=properties/YOUR_PROPERTY_ID

# Service Account JSON 파일 경로 (프로젝트 루트 기준)
GA4_KEY_FILE=./ga4-service-account.json

# --------------------------------------------------
# Gemini API
# --------------------------------------------------
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# (선택) 다른 Google 계정/프로젝트에서 발급한 키 — 무료 티어 쿼터가 별도라서
# 주 키가 429일 때 자동으로 이 키로 한 번 더 시도합니다. 결제 연결 없이도 새 프로젝트 키로 우회 가능.
GEMINI_API_KEY_FALLBACK=
# (선택) 기본 gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
# (선택) 콤마로 구분. 429/404 시 자동으로 아래 모델들도 순서대로 시도합니다(내장 목록보다 먼저).
# GEMINI_EXTRA_MODELS=gemini-2.0-flash-lite,gemini-2.5-flash-lite

# --------------------------------------------------
# Firebase (Firestore — 일간 리포트 저장)
# --------------------------------------------------
# 서비스 계정 JSON의 project_id, client_email, private_key 값을 넣습니다.
# private_key는 한 줄로 쓰고 줄바꿈은 \n 으로 이스케이프하세요.
# 또는 JSON 파일을 프로젝트 루트에 둔 뒤: npm run firebase:env
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --------------------------------------------------
# 서버 설정
# --------------------------------------------------
PORT=3001
